// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Portfolio {
  id String @id @default(cuid())
  slug String @unique
  name String
  title String
  bio String
  draftTheme String @default("modern-minimal")
  publishedTheme String @default("modern-minimal")
  draftTemplate String @default("featured-grid")
  publishedTemplate String @default("featured-grid")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  profilePhotoId String? @unique
  profilePhoto   Asset?  @relation("ProfilePhoto", fields: [profilePhotoId], references: [id])
  
  assets Asset[]
  pages Page[]
  categories Category[]
}

model Page {
  id String @id @default(cuid())
  portfolioId String
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  
  title String
  slug String
  navOrder Int @default(0)
  isHomepage Boolean @default(false)
  showInNav Boolean @default(true)
  
  draftContent String?
  publishedContent String?
  lastPublishedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([portfolioId, slug])
}

model Asset {
  id String @id @default(cuid())
  portfolioId String
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  
  filename String
  mimeType String
  size Int
  
  url String
  thumbnailUrl String
  placeholderUrl String
  
  srcset400 String?
  srcset800 String?
  srcset1200 String?
  srcset1600 String?
  
  width Int
  height Int
  altText String @default("")
  caption String?
  
  createdAt DateTime @default(now())
  
  // Reverse relations for featured images
  categoriesFeatured Category[] @relation("CategoryFeaturedImage")
  profilePortfolio Portfolio? @relation("ProfilePhoto")
  projectsFeatured  Project[] @relation("ProjectFeaturedImage")
}

model Category {
  id String @id @default(cuid())
  portfolioId String
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  
  name String
  slug String
  description String?
  order Int @default(0)
  
  featuredImageId String?
  featuredImage Asset? @relation("CategoryFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)
  
  projects Project[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([portfolioId, slug])
  @@index([portfolioId, order])
}

model Project {
  id String @id @default(cuid())
  categoryId String
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  title String
  slug String

  // Section-based content (like Pages)
  draftContent String?
  publishedContent String?
  lastPublishedAt DateTime?

  // Metadata (in sidebar, not sections)
  year String?
  venue String?
  role String?
  order Int @default(0)
  isFeatured Boolean @default(false)

  featuredImageId String?
  featuredImage   Asset?   @relation("ProjectFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, slug])
  @@index([categoryId, order])
  @@index([isFeatured])
}


