// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Portfolio {
  id String @id @default(cuid())
  name String
  title String?
  bio String? @db.Text
  contactEmail String?
  draftTheme String @default("modern-minimal")
  publishedTheme String @default("modern-minimal")
  draftTemplate String @default("featured-grid")
  publishedTemplate String @default("featured-grid")
  lastPublishedAt DateTime?
  
  // Category list page content (section-based)
  categoryPageDraftContent String? @db.Text
  categoryPagePublishedContent String? @db.Text
  categoryPageLastPublishedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  profilePhotoId String? @unique
  profilePhoto   Asset?  @relation("ProfilePhoto", fields: [profilePhotoId], references: [id])
  
  assets Asset[]
  pages Page[]
  categories Category[]
  tags Tag[]
}

model Page {
  id String @id @default(cuid())
  portfolioId String
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  
  title String
  slug String
  navOrder Int @default(0)
  isHomepage Boolean @default(false)
  showInNav Boolean @default(true)
  
  draftContent String? @db.Text
  publishedContent String? @db.Text
  lastPublishedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([portfolioId, slug])
}

model Asset {
  id String @id @default(cuid())
  portfolioId String
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  
  filename String
  mimeType String
  size Int
  
  url String
  thumbnailUrl String
  placeholderUrl String
  
  srcset400 String?
  srcset800 String?
  srcset1200 String?
  srcset1600 String?
  
  width Int
  height Int
  altText String @default("")
  caption String? @db.Text
  
  createdAt DateTime @default(now())
  
  // Reverse relations for featured images
  categoriesFeatured Category[] @relation("CategoryFeaturedImage")
  profilePortfolio Portfolio? @relation("ProfilePhoto")
  projectsFeatured  Project[] @relation("ProjectFeaturedImage")
  projectGalleryImages ProjectGalleryImage[]
}

model Category {
  id String @id @default(cuid())
  portfolioId String
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  
  name String
  slug String
  description String? @db.Text
  order Int @default(0)
  
  featuredImageId String?
  featuredImage Asset? @relation("CategoryFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)
  
  // Category landing page content (section-based)
  draftContent String? @db.Text
  publishedContent String? @db.Text
  lastPublishedAt DateTime?
  
  projects Project[]
  
  parentId   String?
  parent     Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryHierarchy")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([portfolioId, slug])
  @@index([portfolioId, order])
  @@index([parentId])
}

model Project {
  id String @id @default(cuid())
  categoryId String
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  title String
  slug String

  // Section-based content (like Pages)
  draftContent String? @db.Text
  publishedContent String? @db.Text
  lastPublishedAt DateTime?

  // Metadata (in sidebar, not sections)
  year String?
  venue String?
  role String?
  order Int @default(0)
  isFeatured Boolean @default(false)

  featuredImageId String?
  featuredImage   Asset?   @relation("ProjectFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)

  galleryImages ProjectGalleryImage[]
  tags ProjectTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, slug])
  @@index([categoryId, order])
  @@index([isFeatured])
}

model ProjectGalleryImage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  altText   String   @default("")
  caption   String?  @db.Text
  createdAt DateTime @default(now())

  @@unique([projectId, assetId])
  @@index([projectId, order])
}

model Tag {
  id          String       @id @default(cuid())
  portfolioId String
  portfolio   Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  
  type        String
  value       String
  slug        String
  description String?      @db.Text
  
  projects    ProjectTag[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@unique([portfolioId, type, slug])
  @@unique([portfolioId, type, value])
  @@index([type])
}

model ProjectTag {
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([projectId, tagId])
  @@index([tagId])
}

model AllowedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  
  @@index([email])
}
