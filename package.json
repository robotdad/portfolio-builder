{
  "name": "portfolio-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",

    "lint": "eslint",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:populate": "node scripts/populate-persona-api.js",
    "test:populate:prod": "dotenv -e .env.production.local -- node scripts/populate-persona-api.js",
    "test:populate:sarah": "node scripts/populate-persona-api.js sarah-chen",
    "test:populate:sarah:prod": "dotenv -e .env.production.local -- node scripts/populate-persona-api.js sarah-chen",
    "test:populate:emma": "node scripts/populate-persona-api.js emma-rodriguez",
    "test:populate:emma:prod": "dotenv -e .env.production.local -- node scripts/populate-persona-api.js emma-rodriguez",
    "test:populate:julian": "node scripts/populate-persona-api.js julian-vane",
    "test:populate:julian:prod": "dotenv -e .env.production.local -- node scripts/populate-persona-api.js julian-vane",
    "db:generate": "npx prisma generate",
    "db:setup": "npx prisma migrate deploy",
    "db:seed-admin": "npx tsx src/prisma/seed-admin.ts",
    "db:seed-admin:prod": "dotenv -e .env.production.local -- npx tsx src/prisma/seed-admin.ts",
    "db:reset": "npx tsx src/scripts/reset-db.ts",
    "db:reset:prod": "dotenv -e .env.production.local -- npx tsx src/scripts/reset-db.ts",
    "db:migrate:prod": "dotenv -e .env.production.local -- npx prisma migrate deploy",
    "test:reset": "npm run db:reset",
    "test:setup": "npm run db:setup && npm run db:reset",
    "generate-images": "node scripts/generate-persona-images.js",
    "auth:login": "node scripts/auth-login.js",
    "auth:status": "node scripts/auth-login.js --status",
    "auth:logout": "node scripts/auth-login.js --logout",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.26.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.34.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tiptap/extension-link": "^3.14.0",
    "@tiptap/pm": "^3.14.0",
    "@tiptap/react": "^3.14.0",
    "@tiptap/starter-kit": "^3.14.0",
    "isomorphic-dompurify": "^2.35.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
